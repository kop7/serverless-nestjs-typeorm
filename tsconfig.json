{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "noImplicitAny": false,
    "removeComments": true,
    "lib": ["es2022"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "moduleResolution": "node",
    "types": ["node", "jest"],
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "paths": {
      "@db-config/*": [
        "src/config/*"
      ],
      "@modules/*": [
        "src/modules/*"
      ],
      "@entities/*": [
        "src/entity/*"
      ]
    }
  },
  "exclude": ["node_modules", "dist"]
}
